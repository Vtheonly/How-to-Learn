{
  "name": "el-imtiyaz-school-system",
  "productName": "El-Imtiyaz School System",
  "version": "1.0.0",
  "description": "Professional offline-first school administration system built for El-Imtiyaz private school. Modular, auditable, and engineered for scale.",
  "author": "El-Imtiyaz Engineering",
  "license": "MIT",
  "private": true,
  "main": "dist-main/main/index.js",
  "scripts": {
    "dev": "concurrently -k -n MAIN,RENDERER -c blue,magenta \"npm:dev:main\" \"npm:dev:renderer\"",
    "dev:main": "tsc -p tsconfig.main.json --watch --preserveWatchOutput",
    "dev:renderer": "vite",
    "build": "tsc -p tsconfig.main.json && tsc -p tsconfig.preload.json && vite build",
    "build:main": "tsc -p tsconfig.main.json",
    "build:preload": "tsc -p tsconfig.preload.json",
    "build:renderer": "vite build",
    "start": "npm run build && electron . --no-sandbox",
    "start:dev": "concurrently -k -n ELECTRON,VITE -c yellow,cyan \"wait-on tcp:5173 && cross-env NODE_ENV=development electron . --no-sandbox\" \"vite\"",
    "lint": "eslint . --ext .ts,.tsx",
    "typecheck": "tsc -p tsconfig.main.json --noEmit && tsc -p tsconfig.preload.json --noEmit && tsc -p tsconfig.json --noEmit",
    "package": "npm run build && electron-builder",
    "package:win": "npm run build && electron-builder --win",
    "package:mac": "npm run build && electron-builder --mac",
    "package:linux": "npm run build && electron-builder --linux",
    "clean": "rimraf dist dist-preload dist-main node_modules/.cache",
    "rebuild:sqlite": "node scripts/rebuild-better-sqlite3.js",
    "postinstall": "node scripts/rebuild-better-sqlite3.js"
  },
  "dependencies": {
    "@reduxjs/toolkit": "^2.2.7",
    "better-sqlite3": "^11.3.0",
    "clsx": "^2.1.1",
    "date-fns": "^3.6.0",
    "electron-log": "^5.1.7",
    "electron-store": "^8.2.0",
    "exceljs": "^4.4.0",
    "fuse.js": "^7.0.0",
    "lucide-react": "^0.441.0",
    "papaparse": "^5.4.1",
    "pdfmake": "^0.2.10",
    "qrcode": "^1.5.4",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-hot-toast": "^2.4.1",
    "react-redux": "^9.1.2",
    "react-router-dom": "^6.26.2",
    "recharts": "^2.12.7",
    "uuid": "^10.0.0",
    "winston": "^3.14.2",
    "winston-daily-rotate-file": "^5.0.0",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.11",
    "@types/node": "^20.16.5",
    "@types/papaparse": "^5.3.14",
    "@types/pdfmake": "^0.2.9",
    "@types/qrcode": "^1.5.5",
    "@types/react": "^18.3.5",
    "@types/react-dom": "^18.3.0",
    "@types/uuid": "^10.0.0",
    "@vitejs/plugin-react": "^4.3.1",
    "concurrently": "^9.0.1",
    "cross-env": "^7.0.3",
    "electron": "^32.1.1",
    "electron-builder": "^25.0.5",
    "eslint": "^9.10.0",
    "rimraf": "^6.0.1",
    "typescript": "^5.6.2",
    "vite": "^5.4.5",
    "vite-plugin-electron": "^0.28.8",
    "vite-plugin-electron-renderer": "^0.14.6",
    "wait-on": "^8.0.1"
  },
  "build": {
    "appId": "com.el-imtiyaz.school",
    "productName": "El-Imtiyaz School System",
    "directories": {
      "output": "release",
      "buildResources": "resources"
    },
    "files": [
      "dist/**/*",
      "dist-main/**/*",
      "dist-preload/**/*",
      "resources/**/*",
      "assets/**/*",
      "package.json"
    ],
    "asarUnpack": [
      "**/*.node",
      "node_modules/better-sqlite3/**/*"
    ],
    "win": {
      "target": "nsis",
      "icon": "resources/icon.png"
    },
    "mac": {
      "target": "dmg",
      "icon": "resources/icon.png"
    },
    "linux": {
      "target": [
        "AppImage",
        "deb"
      ],
      "icon": "resources/icon.png"
    }
  }
}
